{
  "name": "omniguard-platform",
  "private": true,
  "version": "2.2.5",
  "type": "module",
  "description": "OmniGuard — AI-Native Enterprise DevSecOps Platform",
  "scripts": {
    "dev": "npm --prefix omniguard-main-main/omniguard run dev",
    "build": "npm --prefix omniguard-main-main/omniguard run build",
