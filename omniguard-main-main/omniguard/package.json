  "bin": {
    "omniguard": "./cli/omniguard.cjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy:local": "bash scripts/deploy-linux.sh",
