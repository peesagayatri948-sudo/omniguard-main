{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "OmniGuard AI-Native Security Platform - Production ECS Fargate Cluster Template",
  "Parameters": {
    "VpcId": {
      "Type": "AWS::EC2::VPC::Id",
      "Description": "VPC ID where OmniGuard will be deployed"
    },
    "SubnetIds": {
      "Type": "List<AWS::EC2::Subnet::Id>",
      "Description": "Subnets for Fargate Task execution and Load Balancer alignment"
    },
    "SupabaseUrl": {
      "Type": "String",
      "Description": "Your OmniGuard Supabase project API Endpoint URL"
    },
    "SupabaseAnonKey": {
      "Type": "String",
      "NoEcho": true,
      "Description": "Your OmniGuard Supabase Anon/Public API Key"
    }
  },
  "Resources": {
    "ECSCluster": {
      "Type": "AWS::ECS::Cluster",
      "Properties": {
        "ClusterName": "omniguard-marketplace"
      }
    },
    "LogGroup": {
      "Type": "AWS::Logs::LogGroup",
      "Properties": {
        "LogGroupName": "/ecs/omniguard-marketplace",
        "RetentionInDays": 30
      }
    },
    "TaskExecutionRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": "OmniGuardMarketplaceExecutionRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ecs-tasks.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        },
        "ManagedPolicyArns": [
          "arn:aws:iam::aws:policy/service-role/AmazonECSTaskExecutionRolePolicy"
        ]
      }
    },
    "TaskRole": {
      "Type": "AWS::IAM::Role",
      "Properties": {
        "RoleName": "OmniGuardMarketplaceTaskRole",
        "AssumeRolePolicyDocument": {
          "Version": "2012-10-17",
          "Statement": [
            {
              "Effect": "Allow",
              "Principal": {
                "Service": "ecs-tasks.amazonaws.com"
              },
              "Action": "sts:AssumeRole"
            }
          ]
        }
      }
    },
    "SecretsManagerSecret": {
      "Type": "AWS::SecretsManager::Secret",
      "Properties": {
        "Name": "omniguard/marketplace/keys",
        "Description": "Entitlement variables mapped from marketplace customer",
        "SecretString": {
          "Fn::Sub": "{\"VITE_SUPABASE_URL\":\"${SupabaseUrl}\",\"VITE_SUPABASE_ANON_KEY\":\"${SupabaseAnonKey}\"}"
        }
      }
    },
    "TaskDefinition": {
      "Type": "AWS::ECS::TaskDefinition",
      "Properties": {
        "Family": "omniguard-marketplace",
        "Cpu": "1024",
        "Memory": "2048",
        "NetworkMode": "awsvpc",
        "RequiresCompatibilities": [
          "FARGATE"
        ],
        "ExecutionRoleArn": {
          "Ref": "TaskExecutionRole"
        },
        "TaskRoleArn": {
          "Ref": "TaskRole"
        },
        "ContainerDefinitions": [
          {
            "Name": "omniguard",
            "Image": "omniguard/enterprise:latest",
            "Essential": true,
            "PortMappings": [
              {
                "ContainerPort": 80,
                "Protocol": "tcp"
              }
            ],
            "Environment": [
              {
                "Name": "VITE_SUPABASE_URL",
                "Value": {
                  "Ref": "SupabaseUrl"
                }
              },
              {
                "Name": "VITE_SUPABASE_ANON_KEY",
                "Value": {
                  "Ref": "SupabaseAnonKey"
                }
              }
            ],
            "LogConfiguration": {
              "LogDriver": "awslogs",
              "Options": {
                "awslogs-group": {
                  "Ref": "LogGroup"
                },
                "awslogs-region": {
                  "Ref": "AWS::Region"
                },
                "awslogs-stream-prefix": "ecs"
              }
            }
          }
        ]
      }
    }
  },
  "Outputs": {
    "ECSClusterArn": {
      "Description": "ARN of the provisioned ECS cluster",
      "Value": {
        "Fn::GetAtt": [
          "ECSCluster",
          "Arn"
        ]
      }
    }
  }
}
