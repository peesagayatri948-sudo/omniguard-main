{
  "schemaVersion": "2.2",
  "description": "Enterprise-wide automatic installation of OmniGuard CLI and VS Code Extension across developer workstations.",
  "parameters": {
    "DaemonUrl": {
      "type": "String",
      "default": "http://omniguard-alb.internal:5185",
      "description": "Target self-hosted backend daemon endpoint."
    },
    "ApiKey": {
      "type": "String",
      "default": "",
      "description": "Secure organization API key (leave blank to require local developer login)."
    }
  },
  "mainSteps": [
    {
      "action": "aws:runPowerShellScript",
      "name": "installOmniGuardCLI",
      "precondition": {
        "StringEquals": [
          "platformType",
          "Windows"
        ]
      },
      "inputs": {
        "runCommand": [
          "Write-Output 'Starting OmniGuard Enterprise Installer...'",
          "if (!(Get-Command npm -ErrorAction SilentlyContinue)) {",
          "  Write-Error 'NPM is required. Please install Node.js.'",
          "  exit 1",
          "}",
          "Write-Output 'Installing OmniGuard CLI globally...'",
          "npm install -g @omniguard/enterprise-cli --registry=https://aws-codeartifact.internal/npm/private/",
          "Write-Output 'Configuring local developer connection...'",
          "New-Item -ItemType Directory -Path $HOME\\.omniguard -Force | Out-Null",
          "const config = @{",
          "  backendUrl = '{{DaemonUrl}}'",
          "  apiKey = '{{ApiKey}}'",
          "}",
          "Set-Content -Path $HOME\\.omniguard\\config.json -Value (ConvertTo-Json config)",
          "Write-Output 'OmniGuard CLI successfully configured.'"
        ]
      }
    },
    {
      "action": "aws:runShellScript",
      "name": "installOmniGuardCLILinux",
      "precondition": {
        "StringEquals": [
          "platformType",
          "Linux"
        ]
      },
      "inputs": {
        "runCommand": [
          "echo 'Starting OmniGuard Linux Installer...'",
          "if ! command -v npm &> /dev/null; then",
          "  echo 'NPM is required. Please install Node.js.'",
          "  exit 1",
          "fi",
          "sudo npm install -g @omniguard/enterprise-cli --registry=https://aws-codeartifact.internal/npm/private/",
          "mkdir -p $HOME/.omniguard",
          "echo '{\"backendUrl\":\"{{DaemonUrl}}\",\"apiKey\":\"{{ApiKey}}\"}' > $HOME/.omniguard/config.json",
          "echo 'OmniGuard CLI configured.'"
        ]
      }
    },
    {
      "action": "aws:runPowerShellScript",
      "name": "installVSCodeExtension",
      "precondition": {
        "StringEquals": [
          "platformType",
          "Windows"
        ]
      },
      "inputs": {
        "runCommand": [
          "if (Get-Command code -ErrorAction SilentlyContinue) {",
          "  Write-Output 'Installing OmniGuard VS Code Extension...'",
          "  code --install-extension omniguard-extension.vsix",
          "} else {",
          "  Write-Output 'VS Code not detected. Skipping extension installation.'",
          "}"
        ]
      }
    },
    {
      "action": "aws:runShellScript",
      "name": "installVSCodeExtensionLinux",
      "precondition": {
        "StringEquals": [
          "platformType",
          "Linux"
        ]
      },
      "inputs": {
        "runCommand": [
          "if command -v code &> /dev/null; then",
          "  echo 'Installing OmniGuard VS Code Extension...'",
          "  code --install-extension omniguard-extension.vsix",
          "else",
          "  echo 'VS Code not detected. Skipping extension installation.'",
          "fi"
        ]
      }
    }
  ]
}
