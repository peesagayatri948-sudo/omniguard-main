#!/usr/bin/env bash
#
# OmniGuard Pre-Push Hook
# Runs full security scan before pushing to remote
#
# Installation: omniguard install-hooks

set -e

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

# Configuration
OMNIGUARD_URL="${OMNIGUARD_URL:-https://api.omniguard.io}"
OMNIGUARD_API_KEY="${OMNIGUARD_API_KEY:-}"
FAIL_ON="${OMNIGUARD_FAIL_ON:-high}"
BYPASS_ENABLED="${OMNIGUARD_BYPASS:-false}"

# Check if bypass
if [ "$BYPASS_ENABLED" = "true" ] && [ -f "$(git rev-parse --git-dir)/omniguard-bypass" ]; then
  echo -e "${YELLOW}[OmniGuard] Pre-push scan bypassed.${NC}"
  exit 0
fi

# Get remote and branch being pushed
remote="$1"
url="$2"

# Get current branch
current_branch=$(git rev-parse --abbrev-ref HEAD)

echo -e "${GREEN}[OmniGuard] Running pre-push security scan...${NC}"
echo -e "  Branch: $current_branch"
echo -e "  Remote: $remote"
echo ""

# Get commits about to be pushed
commits=$(git log "refs/remotes/$remote/$current_branch"..HEAD --oneline 2>/dev/null || git log -1 --oneline HEAD)

# Get files changed in this push
files=$(git diff --name-only "refs/remotes/$remote/$current_branch"..HEAD 2>/dev/null || git diff --name-only HEAD~1..HEAD)

if [ -z "$files" ]; then
  echo -e "${GREEN}[OmniGuard] No changes to scan.${NC}"
  exit 0
fi

# Run full repository scan via API
if [ -n "$OMNIGUARD_API_KEY" ]; then
  repository=$(git remote get-url "$remote\" 2>/dev/null | sed 's/.*github.com[/:]//' | sed 's/.git$//')

  echo -e "${GREEN}[OmniGuard] Triggering full scan for $repository...${NC}"

  response=$(curl -s -X POST \
    -H "Content-Type: application/json\" \
    -H "Authorization: Bearer $OMNIGUARD_API_KEY\" \
    -d "{\"repository\":\"$repository\",\"branch\":\"$current_branch\",\"trigger\":\"pre-push\"}\" \
    "${OMNIGUARD_URL}/scans")

  scan_id=$(echo "$response" | grep -o '"id":"[^"]*"' | head -1 | cut -d'"' -f4)

  if [ -n "$scan_id" ]; then
    echo -e "${GREEN}[OmniGuard] Scan initiated. ID: $scan_id${NC}"
    echo -e "${YELLOW}[OmniGuard] Waiting for scan to complete...${NC}"

    # Poll for completion (with timeout)
    timeout=60
    elapsed=0
    while [ $elapsed -lt $timeout ]; do
      status=$(curl -s -H "Authorization: Bearer $OMNIGUARD_API_KEY\" \
        "${OMNIGUARD_URL}/scans/$scan_id" | grep -o '"status":"[^"]*"' | cut -d'"' -f4)

      if [ "$status" = "completed" ]; then
        break
      elif [ "$status" = "failed" ]; then
        echo -e "${RED}[OmniGuard] Scan failed. Proceeding with push (non-blocking mode).${NC}"
        exit 0
      fi

      sleep 2
      elapsed=$((elapsed + 2))
      echo -n "."
    done
    echo ""

    # Get results
    results=$(curl -s -H "Authorization: Bearer $OMNIGUARD_API_KEY\" \
      "${OMNIGUARD_URL}/scans/$scan_id")

    critical=$(echo "$results" | grep -o '"critical":[0-9]*' | grep -o '[0-9]*' || echo "0")
    high=$(echo "$results" | grep -o '"high":[0-9]*' | grep -o '[0-9]*' || echo "0")
    medium=$(echo "$results" | grep -o '"medium":[0-9]*' | grep -o '[0-9]*' || echo "0")

    # Check fail threshold
    should_fail=false
    case "$FAIL_ON" in
      critical) [ "$critical" -gt 0 ] && should_fail=true ;;
      high) ([ "$critical" -gt 0 ] || [ "$high" -gt 0 ]) && should_fail=true ;;
      medium) ([ "$critical" -gt 0 ] || [ "$high" -gt 0 ] || [ "$medium" -gt 0 ]) && should_fail=true ;;
      low) should_fail=true ;;
    esac

    if [ "$should_fail" = true ]; then
      echo ""
      echo -e "${RED}╔════════════════════════════════════════════════════════════╗${NC}"
      echo -e "${RED}║  OmniGuard: Push blocked due to security findings         ║${NC}"
      echo -e "${RED}╚════════════════════════════════════════════════════════════╝${NC}"
      echo ""
      echo -e "${YELLOW}View details: ${OMNIGUARD_URL}/dashboard/scans/${scan_id}${NC}"
      exit 1
    fi
  fi
fi

echo -e "${GREEN}[OmniGuard] Pre-push check passed. Proceeding with push.${NC}"
exit 0
