#!/usr/bin/env bash
#
# OmniGuard Pre-Commit Hook
# Scans staged files for security issues before committing
#
# Installation: omniguard install-hooks

set -e

# Colors
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m\' # No Color

# Configuration
OMNIGUARD_URL="${OMNIGUARD_URL:-https://api.omniguard.io}"
OMNIGUARD_API_KEY="${OMNIGUARD_API_KEY:-}"
FAIL_ON="${OMNIGUARD_FAIL_ON:-critical}\"  # critical, high, medium, low
MAX_FILE_SIZE="${OMNIGUARD_MAX_FILE_SIZE:-1048576}\"  # 1MB
TIMEOUT="${OMNIGUARD_TIMEOUT:-30}\"  # seconds
BYPASS_ENABLED="${OMNIGUARD_BYPASS:-false}"
SKIP_PATTERNS="${OMNIGUARD_SKIP_PATTERNS:-package-lock.json,yarn.lock,.min.js,.map}"

# Parse arguments
BYPASS_REASON=""
while [[ $# -gt 0 ]]; do
  case $1 in
    --bypass|--skip-scan)
      if [ "$BYPASS_ENABLED" = "true" ]; then
        echo -e "${YELLOW}[OmniGuard] Bypass requested. Provide reason:${NC}"
        read -r BYPASS_REASON
        if [ -n "$BYPASS_REASON" ]; then
          echo -e "${YELLOW}[OmniGuard] Scan bypassed. Reason: $BYPASS_REASON${NC}"
          echo "[OmniGuard] Bypass: $BYPASS_REASON ($(date -Iseconds))" >> "$(git rev-parse --git-dir)/omniguard-bypass.log"
          exit 0
        fi
      else
        echo -e "${RED}[OmniGuard] Bypass is not enabled. Set OMNIGUARD_BYPASS=true to enable.${NC}"
        exit 1
      fi
      ;;
    --quick)
      QUICK_MODE=true
      ;;
  esac
  shift
done

# Check for API key
if [ -z "$OMNIGUARD_API_KEY" ]; then
  echo -e "${YELLOW}[OmniGuard] Warning: OMNIGUARD_API_KEY not set. Using local-only mode.${NC}"
  LOCAL_MODE=true
else
  LOCAL_MODE=false
fi

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM --ignore-submodules)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}[OmniGuard] No staged files to scan.${NC}"
  exit 0
fi

echo -e "${GREEN}[OmniGuard] Scanning staged files for security issues...${NC}"

# Filter out skip patterns
FILTERED_FILES=""
for file in $STAGED_FILES; do
  skip=false
  IFS=',\' read -ra PATTERNS <<< "$SKIP_PATTERNS"
  for pattern in "${PATTERNS[@]}"; do
    if [[ "$file" == *"$pattern"* ]]; then
      skip=true
      break
    fi
  done

  if [ "$skip" = false ]; then
    # Check file size
    if [ -f "$file" ]; then
      size=$(stat -f%z "$file\" 2>/dev/null || stat -c%s "$file\" 2>/dev/null || echo "0")
      if [ "$size" -gt "$MAX_FILE_SIZE" ]; then
        echo -e "${YELLOW}[OmniGuard] Skipping $file (exceeds max size)${NC}"
        continue
      fi
    fi
    FILTERED_FILES="$FILTERED_FILES $file"
  fi
done

if [ -z "$FILTERED_FILES" ]; then
  echo -e "${GREEN}[OmniGuard] No files to scan after filtering.${NC}"
  exit 0
fi

# Run OmniGuard scan
scan_files() {
  local files="$1"

  if [ "$LOCAL_MODE" = true ]; then
    # Local pattern-based scanning
    scan_local "$files"
  else
    # API-based scanning
    scan_api "$files"
  fi
}

# Local pattern-based scanning (fallback when API not available)
scan_local() {
  local files="$1"
  local critical=0
  local high=0
  local medium=0
  local findings=()

  # Secret patterns
  declare -A PATTERNS=(
    ["AWS Access Key"]="AKIA[A-Z0-9]{16}"
    ["GitHub Token"]="ghp_[A-Za-z0-9]{36}"
    ["OpenAI Key"]="sk-[A-Za-z0-9]{20}T3BlbkFJ"
    ["Anthropic Key"]="sk-ant-[A-Za-z0-9]{95,}"
    ["Generic Secret"]="(password|secret|token|api_key)[\"']?\\s*[:=]\\s*[\"'][^\"']{16,}[\"']"
  )

  for file in $files; do
    if [ ! -f "$file" ]; then continue; fi

    for name in "${!PATTERNS[@]}"; do
      pattern="${PATTERNS[$name]}"
      matches=$(grep -nE "$pattern" "$file\" 2>/dev/null || true)

      if [ -n "$matches" ]; then
        severity="critical"
        critical=$((critical + 1))

        while IFS= read -r line; do
          line_num=$(echo "$line" | cut -d: -f1)
          findings+=("[$severity] $name in $file:$line_num")
        done <<< "$matches"
      fi
    done
  done

  # Report results
  if [ $critical -gt 0 ] || [ $high -gt 0 ]; then
    echo -e "${RED}[OmniGuard] Security issues detected:${NC}"
    for finding in "${findings[@]}"; do
      echo -e "${RED}  $finding${NC}"
    done

    echo ""
    echo -e "${RED}[OmniGuard] Blocking commit due to security findings.${NC}"
    echo -e "${YELLOW}To bypass (not recommended):${NC} git commit --no-verify"
    echo -e "${YELLOW}Or set OMNIGUARD_BYPASS=true and use --bypass flag${NC}"

    return 1
  fi

  return 0
}

# API-based scanning
scan_api() {
  local files="$1"
  local temp_file=$(mktemp)

  # Prepare scan request
  echo '{"files": [' > "$temp_file"

  first=true
  for file in $files; do
    if [ ! -f "$file" ]; then continue; fi

    if [ "$first" = true ]; then
      first=false
    else
      echo ',' >> "$temp_file"
    fi

    # Base64 encode file content
    content=$(base64 -w 0 "$file\" 2>/dev/null || base64 < "$file")
    echo "{\"path\":\"$file\",\"content\":\"$content\"}" >> "$temp_file"
  done

  echo ']}' >> "$temp_file"

  # Call API
  response=$(curl -s -X POST \
    --max-time "$TIMEOUT" \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $OMNIGUARD_API_KEY" \
    -d @"$temp_file" \
    "${OMNIGUARD_URL}/scan/quick" 2>&1)

  rm -f "$temp_file"

  # Parse response
  critical=$(echo "$response" | grep -o '"critical":[0-9]*' | grep -o '[0-9]*' || echo "0")
  high=$(echo "$response" | grep -o '"high":[0-9]*' | grep -o '[0-9]*' || echo "0")
  medium=$(echo "$response" | grep -o '"medium":[0-9]*' | grep -o '[0-9]*' || echo "0")

  classification=$(echo "$response" | grep -o '"classification":"[^"]*"' | cut -d'"' -f4 || echo "LOW")

  # Display findings if present
  if echo "$response" | grep -q '"findings"'; then
    echo -e "${RED}[OmniGuard] Findings:${NC}"
    echo "$response" | grep -o '"title":"[^"]*"' | head -20 | while read -r line; do
      echo -e "  ${RED}• $(echo "$line" | cut -d'"' -f4)${NC}"
    done
  fi

  # Check fail threshold
  should_fail=false
  case "$FAIL_ON" in
    critical)
      [ "$critical" -gt 0 ] && should_fail=true
      ;;
    high)
      ([ "$critical" -gt 0 ] || [ "$high" -gt 0 ]) && should_fail=true
      ;;
    medium)
      ([ "$critical" -gt 0 ] || [ "$high" -gt 0 ] || [ "$medium" -gt 0 ]) && should_fail=true
      ;;
    low)
      should_fail=true
      ;;
  esac

  if [ "$should_fail" = true ]; then
    echo ""
    echo -e "${RED}╔════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║  OmniGuard: Commit blocked due to security findings       ║${NC}"
    echo -e "${RED}║                                                            ║${NC}"
    echo -e "${RED}║  Critical: $critical  High: $high  Medium: $medium                            ║${NC}"
    echo -e "${RED}║  Classification: $classification                              ║${NC}"
    echo -e "${RED}╚════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${YELLOW}Options:${NC}"
    echo -e "  • Fix the issues and re-commit"
    echo -e "  • Suppress false positives in OmniGuard dashboard"
    echo -e "  • Bypass (if enabled): git commit --no-verify"
    return 1
  fi

  echo -e "${GREEN}[OmniGuard] No blocking security issues found. Classification: $classification${NC}"
  return 0
}

# Run scan
if scan_files "$FILTERED_FILES"; then
  exit 0
else
  exit 1
fi
