# ============================================================================
# OmniGuard Enterprise — Authoritative Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values.
# Only SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are
# required. Everything else is optional depending on which features you use.
# ============================================================================

# ---- Supabase (REQUIRED) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Frontend (Vite build-time, REQUIRED for dashboard) ----
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ---- App URLs ----
APP_URL=http://localhost:5173
VITE_APP_URL=http://localhost:5173
OMNIGUARD_DASHBOARD_URL=http://localhost:5173

# ---- OmniGuard CLI / Daemon ----
OMNIGUARD_API_URL=https://your-project.supabase.co/functions/v1
OMNIGUARD_API_KEY=
OMNIGUARD_ORG_ID=
OMNIGUARD_FAIL_ON=high
OMNIGUARD_OFFLINE=false
OMNIGUARD_DAEMON_PORT=5175
OMNIGUARD_INVITE_SECRET=

# ---- AI Providers (at least one recommended) ----
AI_PROVIDER=anthropic
AI_FALLBACK_PROVIDER=openai
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=
OLLAMA_HOST=
LITELLM_BASE_URL=
LITELLM_API_KEY=

# ---- AWS (for Bedrock AI provider) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ---- GitHub Integration ----
GITHUB_TOKEN=
GITHUB_REPOSITORY=

# ---- GitLab Integration ----
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com
GITLAB_PROJECT_ID=

# ---- Bitbucket Integration ----
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_WORKSPACE=
BITBUCKET_REPO_SLUG=

# ---- Azure DevOps Integration ----
AZURE_DEVOPS_TOKEN=
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=

# ---- Jira Integration ----
JIRA_HOST=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# ---- ServiceNow Integration ----
SERVICENOW_INSTANCE=
SERVICENOW_USER=
SERVICENOW_PASSWORD=
SERVICENOW_TABLE=incident
SERVICENOW_ASSIGNMENT_GROUP=

# ---- Slack / Teams Notifications ----
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=
GENERIC_WEBHOOK_SECRET=

# ---- Jenkins CI Integration ----
JENKINS_URL=
JENKINS_USER=
JENKINS_TOKEN=
JENKINS_JOB_NAME=

# ---- Okta SSO (optional) ----
OKTA_DOMAIN=
OKTA_ISSUER=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_REDIRECT_URI=
OKTA_POST_LOGOUT_REDIRECT_URI=

# ---- Resend (email notifications, optional) ----
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=noreply@omniguard.app

# ---- NVD API (vulnerability database, optional) ----
NVD_API_KEY=

# ---- Debug ----
DEBUG_EVENTS=false
