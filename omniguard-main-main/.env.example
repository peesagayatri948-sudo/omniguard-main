# ============================================================================
# OmniGuard Enterprise v2.2.5 — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values.
#
# REQUIRED (3):  SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
# REQUIRED for dashboard build: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
# REQUIRED for publishing: NPM_TOKEN
# Everything else is optional — enable features as needed.
# ============================================================================

# ── Supabase Core (REQUIRED — get these from your Supabase dashboard) ──────────
# Settings → API → Project URL, Project API keys
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Vite Frontend Build (REQUIRED for dashboard) ──────────────────────────────
# These MUST mirror SUPABASE_URL and SUPABASE_ANON_KEY — Vite inlines them at
# build time, so they need the VITE_ prefix.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:5173
VITE_APP_URL=http://localhost:5173
OMNIGUARD_DASHBOARD_URL=http://localhost:5173

# ── npm Publishing (REQUIRED for publish-all-v225 scripts) ────────────────────
# Create an access token at npmjs.com → Access Tokens → Generate New Token
# Choose "Automation" type (bypasses 2FA for CI/CD). NEVER commit this.
NPM_TOKEN=

# ============================================================================
# CLI / Daemon
# ============================================================================

# CLI connects to Supabase edge functions via these
OMNIGUARD_API_URL=https://your-project.supabase.co/functions/v1
OMNIGUARD_URL=http://localhost:5175

# API key — generate after signup via dashboard → Settings → API Keys
OMNIGUARD_API_KEY=
OMNIGUARD_ORG_ID=

# Scan behavior
OMNIGUARD_FAIL_ON=high
OMNIGUARD_OFFLINE=false
OMNIGUARD_SCAN_TIER=standard

# Daemon
OMNIGUARD_DAEMON_PORT=5175
OMNIGUARD_HEARTBEAT_INTERVAL=30000
OMNIGUARD_SCAN_INTERVAL=300000
OMNIGUARD_WORKER_ID=
OMNIGUARD_PID_FILE=
OMNIGUARD_LOG_FILE=
OMNIGUARD_LOG_LEVEL=info

# Internal
OMNIGUARD_INVITE_SECRET=
OMNIGUARD_PATHS=
OMNIGUARD_AUDIT_MODE=
OMNIGUARD_TEST=

# ============================================================================
# AI Providers (at least one recommended for AI remediation + semantic scan)
# ============================================================================
AI_PROVIDER=anthropic
AI_FALLBACK_PROVIDER=openai

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Ollama (local LLM, no API key needed)
OLLAMA_BASE_URL=
OLLAMA_HOST=
OLLAMA_URL=

# LiteLLM (proxy to multiple providers)
LITELLM_BASE_URL=
LITELLM_API_KEY=

# ============================================================================
# AWS — Pro Scanning + Bedrock AI
# ============================================================================

# General AWS (also used by Bedrock AI provider)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# Pro scan flags (CLI --aws-scan or set these)
AWS_SCAN_ENABLED=
AWS_SCAN_KEY_ID=
AWS_SCAN_REGION=us-east-1

# ============================================================================
# Okta SSO (optional — auto-detected in production if OKTA_DOMAIN is set)
# ============================================================================
OKTA_DOMAIN=
OKTA_ISSUER=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_REDIRECT_URI=http://localhost:5173/auth/okta/callback
OKTA_POST_LOGOUT_REDIRECT_URI=

# ============================================================================
# Git Provider Integrations (optional)
# ============================================================================

# GitHub
GITHUB_TOKEN=
GITHUB_REPOSITORY=

# GitLab
GITLAB_TOKEN=
GITLAB_URL=https://gitlab.com
GITLAB_PROJECT_ID=

# Bitbucket
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=
BITBUCKET_WORKSPACE=
BITBUCKET_REPO_SLUG=

# Azure DevOps
AZURE_DEVOPS_TOKEN=
AZURE_DEVOPS_ORG=
AZURE_DEVOPS_PROJECT=

# ============================================================================
# Ticketing / ITSM Integrations (optional)
# ============================================================================

# Jira
JIRA_HOST=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=

# ServiceNow
SERVICENOW_INSTANCE=
SERVICENOW_USER=
SERVICENOW_PASSWORD=
SERVICENOW_TABLE=incident
SERVICENOW_ASSIGNMENT_GROUP=

# ============================================================================
# Notification Webhooks (optional)
# ============================================================================
SLACK_WEBHOOK_URL=
TEAMS_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=
GENERIC_WEBHOOK_SECRET=

# ============================================================================
# CI Integrations (optional)
# ============================================================================
JENKINS_URL=
JENKINS_USER=
JENKINS_TOKEN=
JENKINS_JOB_NAME=

# ============================================================================
# Email + Vulnerability DB (optional)
# ============================================================================
RESEND_API_KEY=
NOTIFICATION_FROM_EMAIL=noreply@omniguard.app
NVD_API_KEY=

# ============================================================================
# Database (advanced — only if migrating from Supabase to RDS)
# ============================================================================
DATABASE_URL=
RDS_HOST=
RDS_PORT=5432
RDS_DB=
RDS_USER=
RDS_PASSWORD=

# ============================================================================
# Docker / Cloud Deploy (optional)
# ============================================================================
DOCKER_REGISTRY=
JWT_SECRET=
NODE_ENV=development

# Workspace path for Docker/CI scans
WORKSPACE_PATH=

# ============================================================================
# Debug
# ============================================================================
DEBUG_EVENTS=false
