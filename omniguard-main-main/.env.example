# ==============================================================================
# OMNIGUARD ENTERPRISE CONFIGURATION TEMPLATE (.env)
# ==============================================================================
# Copy this file to `.env` in the root directory and fill in the values.
# Set required variables to deploy OmniGuard.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. DATABASE & SUPABASE CONNECTION (REQUIRED)
# ------------------------------------------------------------------------------
# Description: Endpoint URL for the Supabase database instance.
# Required/Optional: REQUIRED for database sync and dashboard state.
# How to obtain: Create a project at https://supabase.com -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_URL=https://your-project.supabase.co

# Description: Anonymous API key for client-side API requests.
# Required/Optional: REQUIRED for frontend/client auth operations.
# How to obtain: Supabase Settings -> API -> `anon public` key
SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Description: Service Role API Key bypassing Row Level Security (RLS).
# Required/Optional: REQUIRED for daemon backend syncing.
# How to obtain: Supabase Settings -> API -> `service_role` key (Keep secure!)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ------------------------------------------------------------------------------
# 2. APPLICATION URLS
# ------------------------------------------------------------------------------
# Description: Public URL where the frontend is hosted.
# Default: http://localhost:5173 (Vite development dev-server)
APP_URL=http://localhost:5173
VITE_APP_URL=http://localhost:5173

# ------------------------------------------------------------------------------
# 3. AI PROVIDERS (At least one REQUIRED for AI Remediation & Insights)
# ------------------------------------------------------------------------------
# Description: Active AI provider selection ("anthropic" | "openai" | "gemini" | "openrouter" | "ollama" | "litellm").
# Default: "anthropic"
AI_PROVIDER=anthropic

# Description: Anthropic API key for Claude models.
# Required/Optional: REQUIRED if AI_PROVIDER is "anthropic".
# How to obtain: Sign up at https://console.anthropic.com -> Get API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# Description: OpenAI API key for GPT-4 / GPT-4o models.
# Required/Optional: REQUIRED if AI_PROVIDER is "openai".
# How to obtain: Sign up at https://platform.openai.com -> API Keys
OPENAI_API_KEY=your_openai_api_key

# Description: Google Gemini API key for Gemini 1.5 models.
# Required/Optional: REQUIRED if AI_PROVIDER is "gemini".
# How to obtain: Sign up at https://aistudio.google.com -> Get API Key
GEMINI_API_KEY=your_gemini_api_key

# Description: OpenRouter API key for Llama and third-party hosted models.
# Required/Optional: REQUIRED if AI_PROVIDER is "openrouter".
# How to obtain: Sign up at https://openrouter.ai -> Keys
OPENROUTER_API_KEY=your_openrouter_api_key

# Description: Host url for local Ollama server running offline models.
# Required/Optional: OPTIONAL (Defaults to http://localhost:11434 if AI_PROVIDER is "ollama").
OLLAMA_BASE_URL=http://localhost:11434

# Description: Host url for LiteLLM proxy server.
# Required/Optional: OPTIONAL (Defaults to http://localhost:4000 if AI_PROVIDER is "litellm").
LITELLM_BASE_URL=http://localhost:4000

# ------------------------------------------------------------------------------
# 4. ENTERPRISE SSO & IDENTITY (OPTIONAL)
# ------------------------------------------------------------------------------
# Description: Okta Domain for SAML/OIDC Single Sign-On.
OKTA_DOMAIN=yourco.okta.com
OKTA_ISSUER=https://yourco.okta.com/oauth2/default
OKTA_CLIENT_ID=your_okta_client_id
OKTA_CLIENT_SECRET=your_okta_client_secret
OKTA_REDIRECT_URI=http://localhost:5173/login
OKTA_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/

# ------------------------------------------------------------------------------
# 5. CODE HOSTING & VCS INTEGRATIONS (OPTIONAL)
# ------------------------------------------------------------------------------
# Description: GitHub Personal Access Token or App Installation Token.
# Required/Optional: REQUIRED for GitHub Issue/PR Comment integration.
# How to obtain: Github -> Developer Settings -> Personal Access Tokens (repo scope)
GITHUB_TOKEN=your_github_token
GITHUB_REPOSITORY=owner/repo

# Description: GitLab Access Token (Project or Personal).
# Required/Optional: REQUIRED for GitLab issue and merge request comment integrations.
# How to obtain: GitLab -> User Settings -> Access Tokens (api scope)
GITLAB_TOKEN=your_gitlab_token
GITLAB_URL=https://gitlab.com

# Description: Bitbucket credentials for creating team issues.
# Required/Optional: REQUIRED for Bitbucket Cloud integration.
# How to obtain: Bitbucket -> Personal Settings -> App Passwords
BITBUCKET_USERNAME=your_bitbucket_username
BITBUCKET_APP_PASSWORD=your_bitbucket_app_password
BITBUCKET_WORKSPACE=your_workspace_slug
BITBUCKET_REPO_SLUG=your_repo_slug

# Description: Azure DevOps Personal Access Token (PAT).
# Required/Optional: REQUIRED for Azure work item and PR comment integration.
# How to obtain: Azure DevOps Portal -> User settings -> Personal Access Tokens (Work Items/Code scopes)
AZURE_DEVOPS_TOKEN=your_azure_pat
AZURE_DEVOPS_ORG=your_azure_org
AZURE_DEVOPS_PROJECT=your_azure_project

# ------------------------------------------------------------------------------
# 6. CHAT ALERTS & NOTIFICATIONS (OPTIONAL)
# ------------------------------------------------------------------------------
# Description: Incoming Webhook URI for Slack alerts.
# How to obtain: Slack App Directory -> Incoming Webhooks -> Add to Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/X00

# Description: Microsoft Teams connector incoming webhook URI.
# How to obtain: Teams Channel -> Connectors -> Incoming Webhook -> Create
TEAMS_WEBHOOK_URL=https://yourorg.webhook.office.com/webhookb2/xxxx

# Description: Discord channel Webhook URL.
# How to obtain: Discord Channel Settings -> Integrations -> Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx

# Description: Generic target URL for custom JSON payload webhook delivery.
GENERIC_WEBHOOK_URL=https://your-endpoint.com/webhook
GENERIC_WEBHOOK_SECRET=your_signature_token

# ------------------------------------------------------------------------------
# 7. ISSUE TRACKING & ENTERPRISE ticketing (OPTIONAL)
# ------------------------------------------------------------------------------
# Description: Atlassian Jira instance host domain (e.g. company.atlassian.net).
# Required/Optional: REQUIRED for Jira Bug issue provisioning.
# How to obtain: Atlassian Portal -> Account settings -> Security -> API Tokens
JIRA_HOST=your-company.atlassian.net
JIRA_EMAIL=devops@your-company.com
JIRA_API_TOKEN=your_jira_api_token
JIRA_PROJECT_KEY=SEC

# Description: ServiceNow instance domain name.
# Required/Optional: REQUIRED for Incident ticket creations.
# How to obtain: ServiceNow Developer Portal instance credentials
SERVICENOW_INSTANCE=yourinstance
SERVICENOW_USER=admin
SERVICENOW_PASSWORD=your_servicenow_password
SERVICENOW_TABLE=sn_si_incident
SERVICENOW_ASSIGNMENT_GROUP=Security Operations

# ------------------------------------------------------------------------------
# 8. BUILD AND INFRASTRUCTURE (OPTIONAL)
# ------------------------------------------------------------------------------
# Description: Target AWS Region for S3 Bucket and EC2 security group checks.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_SESSION_TOKEN=optional_session_token

# Description: Jenkins pipeline executor integration.
# Required/Optional: REQUIRED for triggering Jenkins security gates.
# How to obtain: Jenkins Server -> User Profile -> Configure -> API Token
JENKINS_URL=http://localhost:8080
JENKINS_USER=jenkins-api-bot
JENKINS_TOKEN=your_jenkins_api_token
JENKINS_JOB_NAME=omniguard-security-gate

# ------------------------------------------------------------------------------
# 9. OMNIGUARD DAEMON & CLI INTERNAL SETTINGS (OPTIONAL)
# ------------------------------------------------------------------------------
# Description: Server port where background scanning webhook daemon listens.
# Default: 5175
OMNIGUARD_DAEMON_PORT=5175

# Description: URL pointing to edge functions API endpoints.
OMNIGUARD_URL=http://localhost:5173/functions/v1
OMNIGUARD_DASHBOARD_URL=http://localhost:5173

# Description: CLI credential token.
OMNIGUARD_API_KEY=
OMNIGUARD_ORG_ID=

# Description: CLI exit code threshold ("critical" | "high" | "medium" | "low").
# If findings at or above this severity are detected, CLI exits with status 1.
OMNIGUARD_FAIL_ON=critical

# Description: Telemetry mode. Set to 1 to run local standalone scan without remote network syncs.
OMNIGUARD_OFFLINE=0

# Description: Enable debug logging on eventBus emitters.
DEBUG_EVENTS=0

# Description: NVD CVE Database request enrichment key.
NVD_API_KEY=
